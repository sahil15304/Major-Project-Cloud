# PPMI Backend Configuration
# Copy this file to .env and modify values for your environment

# Application settings
APP_NAME=PPMI Parkinson's Disease Severity Prediction API
DEBUG=False
LOG_LEVEL=INFO

# Server settings
HOST=0.0.0.0
PORT=8000

# Model settings
# Options: "local" or "s3"
MODELS_SOURCE=local

# Absolute path to the trained model files
# Use the deployment path on AWS or override locally as needed
MODEL_PATH=/home/ubuntu/Major-Project-Cloud/PPMI_Project/models

# Local model path (used when MODELS_SOURCE=local)
# Default: ../models (relative to backend directory)
LOCAL_MODELS_DIR=../models

# AWS S3 settings (only needed if MODELS_SOURCE=s3)
AWS_S3_BUCKET=parkinson-ml-data-roshan
AWS_S3_MODELS_PREFIX=models/
AWS_S3_ARTIFACTS_PREFIX=artifacts/
AWS_REGION=us-east-1

# Do not commit AWS credentials to the repo.
# For local testing, set them in your shell or a local .env file:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...  # optional

# Use IAM role for AWS authentication (recommended for EC2)
# Set to True when running on EC2 with proper IAM role
USE_IAM_ROLE=False

# Logging settings
LOGS_DIR=logs
